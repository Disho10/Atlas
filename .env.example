# Copy this file to .env.local and fill in your real values.
# Never commit .env.local — it's already covered by the .gitignore.

# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to the browser

# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-or-channel-id           # where new-order alerts get posted

# Optional — for order-confirmation emails (pick one provider)
RESEND_API_KEY=your-resend-api-key
RECEIPT_FROM_EMAIL=orders@albayan-lb.com

# Base URL of your deployed site (used in emails / links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
